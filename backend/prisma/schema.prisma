generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "postgresql"
}

model RefreshToken {
  token_id   Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  user       User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("refresh_tokens")
}

