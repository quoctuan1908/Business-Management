## Environment ##
NODE_ENV=production


## Server ##
PORT=8081

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234567
POSTGRES_DB=business_management
DATABASE_URL=postgresql://postgres:1234@localhost:5432/business_management?schema=public


## Setup jet-logger ##
JET_LOGGER_MODE=file
JET_LOGGER_FILEPATH=jet-logger.log
JET_LOGGER_TIMESTAMP=true
JET_LOGGER_FORMAT=line
